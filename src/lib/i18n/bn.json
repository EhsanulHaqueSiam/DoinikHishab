      "desc": "\u099f\u09be\u0995\u09be \u0986\u09b8\u09b2\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u099f\u09be\u0995\u09be \u098f\u0995\u099f\u09bf \u0995\u09cd\u09af\u09be\u099f\u09be\u0997\u09b0\u09bf\u09a4\u09c7 \u09ac\u09b0\u09be\u09a6\u09cd\u09a6 \u0995\u09b0\u09c1\u09a8\u0964 \u0995\u09cb\u09a8\u09cb \u099f\u09be\u0995\u09be \u09ac\u09b8\u09c7 \u09a5\u09be\u0995\u09ac\u09c7 \u09a8\u09be\u0964",
      "example": "\u0986\u09aa\u09a8\u09be\u09b0 \u09e9\u09e6,\u09e6\u09e6\u09e6 \u099f\u09be\u0995\u09be \u09ac\u09c7\u09a4\u09a8 \u0986\u09b8\u09b2\u0964 \u09ee,\u09e6\u09e6\u09e6 \u09ad\u09be\u09a1\u09bc\u09be\u09af\u09bc, \u09eb,\u09e6\u09e6\u09e6 \u09ae\u09c1\u09a6\u09bf \u0996\u09be\u09ac\u09be\u09b0\u09c7, \u09e8,\u09e6\u09e6\u09e6 \u09af\u09be\u09a4\u09be\u09af\u09bc\u09be\u09a4\u09c7... \u09af\u09a4\u0995\u09cd\u09b7\u09a3 \u09a8\u09be \u09e6 \u09ac\u09be\u0995\u09bf \u09a5\u09be\u0995\u09c7\u0964"
    },
    "rule2": {
      "title": "\u09b8\u09a4\u09cd\u09af\u09bf\u0995\u09be\u09b0 \u0996\u09b0\u099a \u09ae\u09c7\u09a8\u09c7 \u09a8\u09bf\u09a8",
      "desc": "\u09ac\u09a1\u09bc, \u0985\u09a8\u09c1\u09ae\u09be\u09a8\u09af\u09cb\u0997\u09cd\u09af \u0996\u09b0\u099a \u099a\u09ae\u0995 \u09a8\u09af\u09bc\u0964 \u098f\u0997\u09c1\u09b2\u09cb \u09ae\u09be\u09b8\u09bf\u0995 \u09aa\u09b0\u09bf\u09ae\u09be\u09a3\u09c7 \u09ad\u09be\u0997 \u0995\u09b0\u09c1\u09a8\u0964",
      "example": "\u0988\u09a6 \u09ea \u09ae\u09be\u09b8 \u09aa\u09b0\u09c7\u0964 \u098f\u0996\u09a8 \u09a5\u09c7\u0995\u09c7 \u09ae\u09be\u09b8\u09c7 \u09e8,\u09eb\u09e6\u09e6 \u09b8\u09b0\u09bf\u09af\u09bc\u09c7 \u09b0\u09be\u0996\u09c1\u09a8\u0964 \u0988\u09a6 \u0986\u09b8\u09b2\u09c7 \u099f\u09be\u0995\u09be \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4\u0964"
    },
    "rule3": {
      "title": "\u09a8\u09ae\u09a8\u09c0\u09af\u09bc \u09a5\u09be\u0995\u09c1\u09a8",
      "desc": "\u0985\u09a4\u09bf\u09b0\u09bf\u0995\u09cd\u09a4 \u0996\u09b0\u099a \u09b9\u09b2\u09c7 \u0985\u09a8\u09cd\u09af \u0995\u09cd\u09af\u09be\u099f\u09be\u0997\u09b0\u09bf \u09a5\u09c7\u0995\u09c7 \u099f\u09be\u0995\u09be \u09b8\u09b0\u09be\u09a8\u0964 \u0985\u09aa\u09b0\u09be\u09a7\u09ac\u09cb\u09a7 \u09a8\u09af\u09bc, \u09b6\u09c1\u09a7\u09c1 \u09b8\u09be\u09ae\u099e\u09cd\u099c\u09b8\u09cd\u09af \u0995\u09b0\u09c1\u09a8\u0964",
      "example": "\u099c\u09b0\u09c1\u09b0\u09bf \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be\u09af\u09bc \u09eb,\u09e6\u09e6\u09e6 \u0985\u09a4\u09bf\u09b0\u09bf\u0995\u09cd\u09a4 \u09b2\u09be\u0997\u09b2\u09cb\u0964 \u09ac\u09bf\u09a8\u09cb\u09a6\u09a8 \u0993 \u09b6\u09aa\u09bf\u0982 \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09bf\u09af\u09bc\u09c7 \u09a8\u09bf\u09a8\u0964"
    },
    "rule4": {
      "title": "\u0986\u09aa\u09a8\u09be\u09b0 \u099f\u09be\u0995\u09be \u09aa\u09c1\u09b0\u09a8\u09cb \u0995\u09b0\u09c1\u09a8",
      "desc": "\u0985\u09a8\u09cd\u09a4\u09a4 \u09e9\u09e6 \u09a6\u09bf\u09a8 \u09aa\u09c1\u09b0\u09a8\u09cb \u099f\u09be\u0995\u09be \u0996\u09b0\u099a \u0995\u09b0\u09c1\u09a8\u0964 \u09ac\u09c7\u09a4\u09a8-\u09a5\u09c7\u0995\u09c7-\u09ac\u09c7\u09a4\u09a8 \u099a\u0995\u09cd\u09b0 \u09ad\u09be\u0999\u09c1\u09a8\u0964",
      "example": "\u09ab\u09c7\u09ac\u09cd\u09b0\u09c1\u09af\u09bc\u09be\u09b0\u09bf\u09b0 \u09ac\u09c7\u09a4\u09a8 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ac\u09bf\u09b2 \u09aa\u09b0\u09bf\u09b6\u09cb\u09a7 \u0995\u09b0\u09c7\u0964 \u099f\u09be\u0995\u09be \u09af\u09a4 \u09aa\u09c1\u09b0\u09a8\u09cb, \u09a4\u09a4 \u09ac\u09c7\u09b6\u09bf \u09b8\u09cd\u09ac\u09b8\u09cd\u09a4\u09bf\u0964"
    },
    "step1": "\u09a8\u09bf\u09af\u09bc\u09ae\u0997\u09c1\u09b2\u09cb \u09b6\u09bf\u0996\u09c1\u09a8",
    "step2": "\u0985\u09cd\u09af\u09be\u0995\u09be\u0989\u09a8\u09cd\u099f \u09af\u09cb\u0997 \u0995\u09b0\u09c1\u09a8",
    "step2Desc": "\u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09ac\u099a\u09c7\u09af\u09bc\u09c7 \u09ac\u09c7\u09b6\u09bf \u09ac\u09cd\u09af\u09ac\u09b9\u09c3\u09a4 \u0985\u09cd\u09af\u09be\u0995\u09be\u0989\u09a8\u09cd\u099f \u09a6\u09bf\u09af\u09bc\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c1\u09a8",
    "step3": "\u0995\u09cd\u09af\u09be\u099f\u09be\u0997\u09b0\u09bf \u09ac\u09be\u099b\u09be\u0987 \u0995\u09b0\u09c1\u09a8",
