{
  "name": "doinikhishab",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "NODE_OPTIONS='--max-old-space-size=3072 --expose-gc' expo start",
    "android": "NODE_OPTIONS='--max-old-space-size=3072 --expose-gc' expo start --android",
    "ios": "NODE_OPTIONS='--max-old-space-size=3072 --expose-gc' expo start --ios",
    "web": "NODE_OPTIONS='--max-old-space-size=3072 --expose-gc' expo start --web",
    "start:clear": "NODE_OPTIONS='--max-old-space-size=3072' expo start --clear",
    "nuke": "rm -rf node_modules .expo bun.lockb && bun install",
    "lint": "bunx @biomejs/biome check app/ src/ convex/",
    "lint:fix": "bunx @biomejs/biome check --write app/ src/ convex/",
    "format": "bunx @biomejs/biome format --write app/ src/ convex/",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-navigation/native": "^7.1.28",
    "@shopify/flash-list": "^2.3.0",
    "convex": "^1.32.0",
    "expo": "~55.0.6",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.7",
    "expo-document-picker": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "sonner-native": "^0.23.1",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "lefthook": "^2.1.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
